{
  "name": "@ston-fi/omniston-sdk",
  "version": "0.8.1",
  "description": "Typescript SDK for the STON.fi Omniston protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ston-fi/omniston-sdk.git",
    "directory": "packages/omniston-sdk"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch ./src",
    "build": "tsdown",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "proto:generate": "node scripts/generate-proto.js",
    "prepublishOnly": "turbo run build && pnpm run lint && pnpm run test --run"
  },
  "dependencies": {
    "isomorphic-ws": "5.0.0",
    "json-rpc-2.0": "1.7.1",
    "rxjs": "catalog:",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@protobuf-ts/protoc": "2.11.1",
    "@types/node": "25.6.0",
    "@types/ws": "8.18.1",
    "protobufjs": "8.0.1",
    "publint": "catalog:",
    "ts-proto": "2.11.6",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
